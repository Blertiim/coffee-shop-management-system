DATABASE_URL="mysql://root:@localhost:3306/coffee_shop_management"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=5000
HOST=0.0.0.0
# Comma-separated list, example:
# CORS_ORIGINS="http://localhost:5173,http://192.168.1.50:5173"
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
# Optional desktop-app serving helpers
SERVE_FRONTEND_DIST="false"
FRONTEND_DIST_PATH=""
BACKEND_ENV_PATH=""
# Optional XAMPP/MySQL desktop launcher helpers
AUTO_START_XAMPP_MYSQL="true"
XAMPP_PATH="C:\\xampp"
# Optional override for QR links shared to phones/tablets.
# Example: GUEST_ORDER_PUBLIC_BASE_URL="http://192.168.1.50:5000"
GUEST_ORDER_PUBLIC_BASE_URL=""
# Optional automation output directories
BACKUP_OUTPUT_DIR="./backups"
BACKUP_SYNC_DIR=""
REPORT_OUTPUT_DIR="./reports"
REPORT_SYNC_DIR=""
INVENTORY_ALERT_RETRY_MS=30000
